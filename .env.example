# =============================================================================
# SEO Auditor Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# AI Provider API Keys
# -----------------------------------------------------------------------------
# At least one is required for AI-powered suggestions
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# -----------------------------------------------------------------------------
# Search API (for SERP analysis)
# -----------------------------------------------------------------------------
# SerpAPI key (get one at https://serpapi.com - 100 free searches/month)
# If not set, uses manual competitors list below
SERPAPI_KEY=

# -----------------------------------------------------------------------------
# Manual Competitors (used when SERPAPI_KEY is not set)
# -----------------------------------------------------------------------------
# Comma-separated list of competitor domains (up to 5)
# The script will crawl these and compare them against your page
COMPETITORS=competitor1.com,competitor2.com,competitor3.com

# AI Provider: "auto", "claude", or "openai"
# auto = uses whichever key is available (prefers Claude)
AI_PROVIDER=auto

# AI Model overrides (leave empty for defaults)
# Claude default: claude-sonnet-4-20250514
# OpenAI default: gpt-4.1-mini (cheapest good option)
# Other OpenAI options: gpt-5-mini, gpt-5-nano
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4.1-mini

# -----------------------------------------------------------------------------
# Email / SMTP Configuration
# -----------------------------------------------------------------------------
# Alert emails (comma-separated list)
ALERT_EMAILS=webdev@example.com,seo@example.com

# SMTP Server settings
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=

# SMTP encryption mode (choose one):
#   none     - No encryption (port 25)
#   starttls - STARTTLS explicit TLS (port 587)
#   ssl      - Implicit SSL/TLS (port 465)
SMTP_ENCRYPTION=none

# -----------------------------------------------------------------------------
# Google Search Configuration
# -----------------------------------------------------------------------------
# Google country domain for localized results (e.g., co.uk, com, de, fr)
GOOGLE_COUNTRY=co.uk
GOOGLE_LANG=en
GOOGLE_NUM_RESULTS=10

# -----------------------------------------------------------------------------
# Audit Settings
# -----------------------------------------------------------------------------
# Number of competitors to analyze
TOP_COMPETITORS=5

# Request settings
REQUEST_TIMEOUT=15
REQUEST_DELAY=2

# Content analysis thresholds
MIN_CONTENT_WORDS=300
MAX_TITLE_LENGTH=60
MAX_META_DESC_LENGTH=160
MIN_META_DESC_LENGTH=50

# -----------------------------------------------------------------------------
# Output Settings
# -----------------------------------------------------------------------------
# Directory where HTML reports are saved (use ./reports for project-relative)
REPORT_DIR=./reports

# -----------------------------------------------------------------------------
# Batch Script Settings
# -----------------------------------------------------------------------------
# Path to the main auditor script (for seo-audit-batch.py)
AUDITOR_SCRIPT_PATH=/opt/scripts/seo-auditor.py

# Delay between batch audits (seconds) to avoid rate limits
BATCH_DELAY=30

# -----------------------------------------------------------------------------
# WordPress API (for article generator)
# -----------------------------------------------------------------------------
# Your WordPress site URL
WP_URL=https://your-site.com

# WordPress username
WP_USER=your-username

# Application Password (generate in WordPress: Users > Profile > Application Passwords)
WP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Default post status: draft, publish, pending
WP_DEFAULT_STATUS=draft

# Output directory for generated articles
ARTICLE_OUTPUT_DIR=./articles
